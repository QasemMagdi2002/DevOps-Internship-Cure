APP_ENV=development
APP_NAME=CURE Patient Portal API
API_VERSION=1.0.0

DATABASE_URL=postgresql+psycopg2://cure_app:change_this_local_password@postgres:5432/cure_db
DB_AUTO_CREATE=true

JWT_SECRET=replace_with_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

AWS_REGION=me-south-1
S3_BUCKET_NAME=cure-devops-medical-documents-yourname
MAX_UPLOAD_SIZE_MB=5

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=